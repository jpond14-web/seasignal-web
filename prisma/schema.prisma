  company_id         String         @db.Uuid
  vessel_id          String?        @db.Uuid
  issue_id           String?        @db.Uuid
  category           flare_category
  severity           flare_severity @default(concern)
  title              String
  description        String?
  incident_date_start DateTime?     @db.Date
  incident_date_end  DateTime?      @db.Date
  attachments        Json?          @default("[]")
  is_anonymous       Boolean?       @default(true)
  batch_release_at   DateTime?      @db.Timestamptz(6)
  status             flare_status?  @default(pending)
  admin_notes        String?
  created_at         DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?      @default(now()) @db.Timestamptz(6)

  companies                    companies                      @relation(fields: [company_id], references: [id], onUpdate: NoAction)
  profiles                     profiles                       @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vessels                      vessels?                        @relation(fields: [vessel_id], references: [id], onUpdate: NoAction)
  signal_issues                signal_issues?                  @relation(fields: [issue_id], references: [id], onUpdate: NoAction)
  signal_flare_corroborations  signal_flare_corroborations[]

  @@index([company_id], map: "idx_flares_company")
  @@index([status], map: "idx_flares_status")
  @@index([category], map: "idx_flares_category")
  @@index([issue_id], map: "idx_flares_issue")
  @@index([batch_release_at], map: "idx_flares_batch", where: raw("(status = 'pending'::flare_status)"))
  @@schema("public")
}

/// Signal Flare corroboration: another seafarer confirming they witnessed the same issue
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model signal_flare_corroborations {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flare_id   String        @db.Uuid
  profile_id String        @db.Uuid
  vessel_id  String?       @db.Uuid
  statement  String?
  created_at DateTime?     @default(now()) @db.Timestamptz(6)

  signal_flares signal_flares @relation(fields: [flare_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles      profiles      @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vessels       vessels?      @relation(fields: [vessel_id], references: [id], onUpdate: NoAction)

  @@unique([flare_id, profile_id])
  @@index([flare_id], map: "idx_corroborations_flare")
  @@index([profile_id], map: "idx_corroborations_profile")
  @@schema("public")
}

/// Signal Issue: aggregated issue (company + category), tracks lifecycle from monitoring to resolution
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model signal_issues {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id             String       @db.Uuid
  category               flare_category
  stage                  issue_stage  @default(monitoring)
  assigned_to            String?      @db.Uuid
  flare_count            Int?         @default(0)
  corroboration_total    Int?         @default(0)
  vessel_count           Int?         @default(0)
  first_reported_at      DateTime?    @db.Timestamptz(6)
  last_reported_at       DateTime?    @db.Timestamptz(6)
  company_contacted_at   DateTime?    @db.Timestamptz(6)
  company_response       String?
  company_responded_at   DateTime?    @db.Timestamptz(6)
  resolution_description String?
  resolution_date        DateTime?    @db.Timestamptz(6)
  resolution_verified_by String?      @db.Uuid
  is_recurring           Boolean?     @default(false)
  article_id             String?      @unique @db.Uuid
  created_at             DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?    @default(now()) @db.Timestamptz(6)

  companies       companies        @relation(fields: [company_id], references: [id], onUpdate: NoAction)
  assigned_profile profiles?        @relation("issue_assigned", fields: [assigned_to], references: [id], onUpdate: NoAction)
  signal_flares   signal_flares[]
  signal_articles signal_articles? @relation(fields: [article_id], references: [id], onUpdate: NoAction)
  signal_outreach_log signal_outreach_log[]

  @@unique([company_id, category])
  @@index([company_id], map: "idx_issues_company")
  @@index([stage], map: "idx_issues_stage")
  @@schema("public")
}

/// Signal Article: editorial content (investigations, guides, resolution spotlights)
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
